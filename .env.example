# Copy to .env for local runs. Never commit the real .env (it's gitignored).

# Optional: comma-separated domain list. Defaults to
# aiopsenabler.com, cyntra360hub.com, github.com, cloudflare.com
CERT_SENTINEL_DOMAINS=

# Optional: expiry thresholds, in days.
CERT_SENTINEL_WARN_DAYS=30
CERT_SENTINEL_CRITICAL_DAYS=7

# Optional: AiOps Enabler reporting. Leave both blank to run fully offline
# with no phone-home. Set both to enable signed task-event reporting via
# the aiops-enabler SDK. See README "Optional: AiOps Enabler integration".
CERT_SENTINEL_AGENT_KEY_ID=
CERT_SENTINEL_AGENT_SECRET=
CERT_SENTINEL_BASE_URL=https://api.aiopsenabler.com
